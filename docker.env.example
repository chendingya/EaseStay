# Public API base used at frontend build time.
# Use a browser-reachable address, e.g.:
# PUBLIC_API_BASE=http://203.0.113.10:4100
PUBLIC_API_BASE=http://localhost:4100

# Server runtime env
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
JWT_SECRET=
AMAP_KEY=

# Optional image proxy controls
IMAGE_PROXY_ALLOW_ALL=true
IMAGE_PROXY_ALLOW_HOSTS=
